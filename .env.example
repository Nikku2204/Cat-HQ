# ── Cat HQ configuration ────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Defaults below are fine for M0 — nothing is required until its milestone.

# Core
CATHQ_AUTH_TOKEN=change-me          # generate one: openssl rand -hex 32   (used from M5)
TZ=America/New_York                 # your IANA timezone — CHANGE ME
CAT_NAMES=                          # comma-separated, cosmetic, e.g. "Miso,Mochi"
BUILD_SHA=dev                       # optional: stamped into /health by your deploy step

# Database (used from M3)
DATABASE_PATH=/data/cathq.db

# Whisker / Litter-Robot 4 (used from M1)
WHISKER_EMAIL=
WHISKER_PASSWORD=

# Petlibro (used from M2)
# IMPORTANT: use the DEDICATED second account (see 02-INTEGRATIONS.md).
# Petlibro allows only ONE active session per account — using your main
# account here logs your phone app out.
PETLIBRO_EMAIL=
PETLIBRO_PASSWORD=

# Tapo camera (used from M6)
# These are the local "Camera Account" credentials created in the Tapo app
# under Third-Party Compatibility — NOT your TP-Link cloud login.
TAPO_CAM_IP=
TAPO_CAM_USER=
TAPO_CAM_PASS=
