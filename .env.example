# ── Cat HQ configuration ────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Defaults below are fine for M0 — nothing is required until its milestone.
#
# NOTE: comments always go on their own line. Inline comments (VAR=x  # ...)
# are parsed inconsistently between docker compose and python-dotenv — with
# an empty value the comment silently BECOMES the value.

# Core
# CATHQ_AUTH_TOKEN: REQUIRED from M5 — the backend refuses to start when this
# is empty or "change-me" (it gates endpoints that move real hardware).
# Generate one with `openssl rand -hex 32`
CATHQ_AUTH_TOKEN=
# ENABLE_DOCS: true exposes /docs + /openapi.json (dev only — the schema maps
# the whole control surface; leave false in production)
ENABLE_DOCS=false
# TZ: your IANA timezone — CHANGE ME
TZ=America/New_York
# CAT_NAMES: comma-separated, cosmetic, e.g. Miso,Mochi
CAT_NAMES=
# BUILD_SHA: optional, stamped into /health by your deploy step
BUILD_SHA=dev

# Database (used from M3)
DATABASE_PATH=/data/cathq.db

# Whisker / Litter-Robot 4 (used from M1)
WHISKER_EMAIL=
WHISKER_PASSWORD=

# Petlibro (used from M2)
# IMPORTANT: use the DEDICATED second account (see 02-INTEGRATIONS.md).
# Petlibro allows only ONE active session per account — using your main
# account here logs your phone app out.
PETLIBRO_EMAIL=
PETLIBRO_PASSWORD=

# Govee smart plugs (used from M5.5 — see docs/05-PLUG-AND-UX-SPEC.md)
# GOVEE_API_KEY: Govee Home app → profile → Settings → Apply for API Key
GOVEE_API_KEY=
# Plug bindings: the EXACT device name from the Govee app. Power commands
# are refused for any plug not explicitly bound here (never switch the
# wrong mains socket).
GOVEE_PLUG_LITTERROBOT=
GOVEE_PLUG_FEEDER=
# POWER_CYCLE_DELAY_S: seconds a power_cycle keeps the plug OFF before
# switching back on
POWER_CYCLE_DELAY_S=8

# Tapo camera (used from M6)
# These are the local "Camera Account" credentials created in the Tapo app
# under Third-Party Compatibility — NOT your TP-Link cloud login.
TAPO_CAM_IP=
TAPO_CAM_USER=
TAPO_CAM_PASS=
